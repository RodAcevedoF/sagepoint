# =============================================================================
# Sagepoint — Production Environment Variables
# Copy to .env.production and fill in real values
# =============================================================================

# --- Database (shared Postgres) ---
DATABASE_URL=postgresql://admin:CHANGE_ME@shared_postgres:5432/sagepoint?schema=public

# --- Redis (shared, using DB 2 to avoid conflicts) ---
REDIS_HOST=shared_redis
REDIS_PORT=6379
# REDIS_DB=2  # Uncomment when app supports DB selection

# --- Neo4j ---
NEO4J_URI=bolt://shared_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- API ---
PORT=3001
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
CORS_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com

# --- Auth ---
RESTRICT_AUTH_TO_ADMIN=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback

# --- Storage (GCS) ---
STORAGE_DRIVER=gcs
GCP_PROJECT_ID=sagepoint-point-project
GCS_BUCKET_NAME=sagepoint-store
GCP_KEY_FILE=/app/gcp-key.json

# --- AI ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# AI Model Selection
MODEL_ROADMAP_GENERATION=gpt-4o
MODEL_TOPIC_CONCEPT_GENERATION=gpt-4o
MODEL_QUIZ_GENERATION=gpt-4o-mini
MODEL_DOCUMENT_ANALYSIS=gpt-4o-mini
MODEL_CONTENT_ANALYSIS=gpt-4o-mini
MODEL_VISION_TEXT_EXTRACTION=gpt-4o-mini
MODEL_CONCEPT_EXPANSION=gpt-4o-mini

# --- Bull Board ---
BULL_BOARD_USER=admin
BULL_BOARD_PASS=CHANGE_ME

# --- Sentry ---
SENTRY_DSN=

# --- News ---
NEWS_REFRESH_ENABLED=true
TAVILY_API_KEY=
THE_NEWS_API_KEY=
NEWSDATAIO_API_KEY=
