generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserRole {
  ADMIN
  USER
}

enum OnboardingStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum ResourceType {
  ARTICLE
  VIDEO
  COURSE
  DOCUMENTATION
  TUTORIAL
  BOOK
}

enum RoadmapGenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum StepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ProcessingStage {
  UPLOADED
  PARSING
  ANALYZING
  SUMMARIZED
  READY
}

enum RoadmapVisibility {
  PRIVATE
  PUBLIC
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  password  String?
  googleId  String?  @unique
  role      UserRole @default(USER)
  avatarUrl String?
  isActive  Boolean  @default(true)
  isVerified Boolean @default(false)
  verificationToken String?

  learningGoal     String?  // "Become a DevOps Engineer"
  onboardingStatus OnboardingStatus @default(PENDING)
  interests        UserInterest[]
  preferences      UserPreferences?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
  roadmaps  Roadmap[]

  invitationsSent     Invitation[] @relation("InvitedByUser")
  invitationsAccepted Invitation[] @relation("AcceptedInvitation")
  roadmapLikes        RoadmapLike[]

  @@index([verificationToken])
  @@index([onboardingStatus])
  @@map("users")
}

model UserInterest {
  userId     String   @db.Uuid
  categoryId String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
  @@map("user_interests")
}

model UserPreferences {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Learning preferences
  weeklyHoursGoal  Int?     // Hours per week user wants to study
  experienceLevel  String?  // beginner, intermediate, advanced
  preferredFormat  String?  // video, text, interactive

  // Notification preferences
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)

  // UI preferences
  theme String @default("system") // light, dark, system

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

model Document {
  id              String           @id @default(uuid()) @db.Uuid
  filename        String
  status          String
  storagePath     String
  errorMessage    String?
  processingStage ProcessingStage  @default(UPLOADED)
  mimeType        String?
  fileSize        Int?
  conceptCount    Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userId          String           @db.Uuid
  user            User             @relation(fields: [userId], references: [id])

  roadmaps        Roadmap[]
  summary         DocumentSummary?
  quizzes         Quiz[]

  @@index([userId])
  @@index([processingStage])
  @@map("documents")
}

model DocumentSummary {
  id                String   @id @default(uuid()) @db.Uuid
  documentId        String   @unique @db.Uuid
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  overview          String   @db.Text
  keyPoints         Json
  topicArea         String
  difficulty        String
  estimatedReadTime Int?
  conceptCount      Int      @default(0)
  createdAt         DateTime @default(now())

  @@map("document_summaries")
}

model Quiz {
  id            String        @id @default(uuid()) @db.Uuid
  documentId    String        @db.Uuid
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  questionCount Int           @default(0)
  questions     Question[]
  attempts      QuizAttempt[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([documentId])
  @@map("quizzes")
}

model Question {
  id         String       @id @default(uuid()) @db.Uuid
  quizId     String       @db.Uuid
  quiz       Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type       QuestionType
  text       String       @db.Text
  options    Json
  explanation String?
  conceptId  String?
  order      Int          @default(0)
  difficulty String
  createdAt  DateTime     @default(now())

  @@index([quizId])
  @@map("questions")
}

model QuizAttempt {
  id             String    @id @default(uuid()) @db.Uuid
  quizId         String    @db.Uuid
  quiz           Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId         String    @db.Uuid
  answers        Json
  score          Float
  totalQuestions  Int
  correctAnswers Int
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  parentId    String?  @db.Uuid
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roadmaps     Roadmap[]
  users        UserInterest[]
  newsArticles NewsArticle[]

  @@map("categories")
}

model NewsArticle {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String
  url          String   @unique
  imageUrl     String?
  source       String
  publishedAt  DateTime
  categoryId   String   @db.Uuid
  category     Category @relation(fields: [categoryId], references: [id])
  createdAt    DateTime @default(now())

  @@index([categoryId])
  @@index([createdAt])
  @@map("news_articles")
}

model Roadmap {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?

  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id])

  documentId  String?  @db.Uuid
  document    Document? @relation(fields: [documentId], references: [id])

  categoryId  String?  @db.Uuid
  category    Category? @relation(fields: [categoryId], references: [id])

  steps              Json     // Storing steps as JSON for simplicity, or could be separate model
  generationStatus   RoadmapGenerationStatus @default(PENDING)
  totalDuration      Int?     // Total estimated duration in minutes
  recommendedPace    String?  // e.g., "2-3 concepts per week"
  errorMessage       String?
  isFeatured         Boolean @default(false)
  visibility         RoadmapVisibility @default(PRIVATE)

  resources         Resource[]
  progress          UserRoadmapProgress[]
  stepQuizAttempts  StepQuizAttempt[]
  likes             RoadmapLike[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([documentId])
  @@index([categoryId])
  @@index([generationStatus])
  @@index([isFeatured])
  @@index([visibility])
  @@map("roadmaps")
}

model Resource {
  id                String       @id @default(uuid()) @db.Uuid
  title             String
  url               String
  type              ResourceType
  description       String?
  provider          String?
  estimatedDuration Int?         // in minutes
  difficulty        String?      // beginner, intermediate, advanced
  conceptId         String       // ID of the concept this resource is for
  order             Int          @default(0)

  roadmapId         String       @db.Uuid
  roadmap           Roadmap      @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  createdAt         DateTime     @default(now())

  @@index([conceptId])
  @@index([roadmapId])
  @@map("resources")
}

model UserRoadmapProgress {
  userId      String   @db.Uuid
  roadmapId   String   @db.Uuid
  conceptId   String
  status      StepStatus @default(NOT_STARTED)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  roadmap     Roadmap    @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@id([userId, roadmapId, conceptId])
  @@index([userId])
  @@index([roadmapId])
  @@index([userId, roadmapId])  // Composite for efficient user+roadmap queries
  @@map("user_roadmap_progress")
}

model StepQuizAttempt {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  roadmapId      String    @db.Uuid
  conceptId      String
  questions      Json      // StepQuizQuestion[] with isCorrect flags
  answers        Json?     // User answers, null until submitted
  score          Float     @default(0)
  totalQuestions  Int       @default(3)
  correctAnswers Int       @default(0)
  passed         Boolean   @default(false)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  roadmap        Roadmap   @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([userId, roadmapId, conceptId])
  @@index([userId])
  @@map("step_quiz_attempts")
}

model Invitation {
  id           String           @id @default(uuid()) @db.Uuid
  email        String
  token        String           @unique
  role         UserRole         @default(USER)
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime

  invitedById  String           @db.Uuid
  invitedBy    User   @relation("InvitedByUser", fields: [invitedById], references: [id])

  acceptedById String?          @db.Uuid
  acceptedBy   User?  @relation("AcceptedInvitation", fields: [acceptedById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([token])
  @@index([status])
  @@map("invitations")
}

model RoadmapLike {
  userId    String   @db.Uuid
  roadmapId String   @db.Uuid
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@id([userId, roadmapId])
  @@index([roadmapId])
  @@index([userId])
  @@map("roadmap_likes")
}
