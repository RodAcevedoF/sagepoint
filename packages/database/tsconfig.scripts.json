{
  "compilerOptions": {
    "composite": true,
    "module": "commonjs",
    "target": "ES2021",
    "outDir": "./dist-scripts",
    "rootDir": "./scripts",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strictNullChecks": false,
    "noImplicitAny": false
  },
  "include": [
    "scripts/migration-runner.ts",
    "scripts/migrate.ts",
    "scripts/init.ts",
    "scripts/bootstrap.ts",
    "scripts/env.ts",
    "scripts/seeds/*.ts"
  ]
}
