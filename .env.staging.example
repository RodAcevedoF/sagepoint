# =============================================================================
# Sagepoint — Staging Environment Variables
# Copy to .env.staging and fill in real values
# =============================================================================

# --- Database (shared Postgres, staging DB) ---
DATABASE_URL=postgresql://admin:CHANGE_ME@shared_postgres:5432/sagepoint_staging?schema=public

# --- Redis (shared, using DB 3 to isolate staging queues) ---
REDIS_HOST=shared_redis
REDIS_PORT=6379
# REDIS_DB=3  # Uncomment when app supports DB selection

# --- Neo4j (shared instance) ---
NEO4J_URI=bolt://shared_neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- API ---
PORT=3002
JWT_SECRET=CHANGE_ME_GENERATE_DIFFERENT_FROM_PROD
CORS_ORIGINS=http://localhost:3000,https://staging.sagepoint.online

# --- Auth ---
RESTRICT_AUTH_TO_ADMIN=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://staging-api.sagepoint.online/auth/google/callback

# --- Storage (GCS) ---
STORAGE_DRIVER=gcs
GCP_PROJECT_ID=sagepoint-point-project
GCS_BUCKET_NAME=sagepoint-store
GCP_KEY_FILE=/app/gcp-key.json

# --- AI ---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# AI Model Selection (use cheaper models for staging)
MODEL_ROADMAP_GENERATION=gpt-4o-mini
MODEL_TOPIC_CONCEPT_GENERATION=gpt-4o-mini
MODEL_QUIZ_GENERATION=gpt-4o-mini
MODEL_DOCUMENT_ANALYSIS=gpt-4o-mini
MODEL_CONTENT_ANALYSIS=gpt-4o-mini
MODEL_VISION_TEXT_EXTRACTION=gpt-4o-mini
MODEL_CONCEPT_EXPANSION=gpt-4o-mini

# --- Bull Board ---
BULL_BOARD_USER=admin
BULL_BOARD_PASS=CHANGE_ME

# --- Sentry ---
SENTRY_DSN=

# --- News ---
NEWS_REFRESH_ENABLED=true
TAVILY_API_KEY=
THE_NEWS_API_KEY=
NEWSDATAIO_API_KEY=

# --- Email ---
EMAIL_PROVIDER=mock
